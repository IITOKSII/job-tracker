rules_version = '2';

// ── WorkAble Firestore Security Rules ──────────────────────────────────────
//
// Schema (all data lives under users/{userId}):
//
//   users/{userId}/settings/{key}
//     → { value: any, updated: string (ISO) }
//
//   users/{userId}/data/{name}          name ∈ { "jobs", "resumes", "covers" }
//     → { items: string (JSON array), updated: string (ISO) }
//
// Access pattern: Owner-Only — a user can only read/write their own documents.
// No cross-user access is permitted under any circumstance.
// ────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Owner-only access to all sub-collections under the user's document
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
